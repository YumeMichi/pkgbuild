# Maintainer:  Gustavo Alvarez <sl1pkn07@gmail.com>

_plug=bm3d
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=10.0.g5b38527
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT version)"
arch=('x86_64')
url='https://forum.doom9.org/showthread.php?t=172172'
license=('MIT')
depends=(
  'vapoursynth'
  'fftw'
)
makedepends=(
  'git'
  'meson'
)
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
source=("${_plug}::git+https://github.com/HomeOfVapourSynthEvolution/VapourSynth-BM3D.git")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  echo "$(git describe --long --tags | tr - . | tr -d r)"
}

prepare() {
  cd "${_plug}"
  rm -rf dist build
}

build() {
  cd "${_plug}"
  python -m build --wheel
}

package(){
  cd "${_plug}"
  python -m installer --destdir="${pkgdir}" dist/*.whl
  install -Dm644 README.md "${pkgdir}/usr/share/doc/vapoursynth/plugins/${pkgname}/README.md"
}
