# Maintainer: Gustavo Alvarez <sl1pkn07@gmail.com>

_plug=lsmashsource
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=r1282.0079a06
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT version)"
arch=('x86_64')
url='https://forum.doom9.org/showthread.php?t=167435'
license=('LGPL')
depends=(
  'vapoursynth'
  'libavutil.so'
  'libavformat.so'
  'libavcodec.so'
  'libswscale.so'
  'liblsmash.so'
)
makedepends=(
  'git'
  'meson'
)
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
source=(
  "${_plug}::git+https://github.com/HomeOfAviSynthPlusEvolution/L-SMASH-Works.git"
  "0001.patch"
)
sha256sums=(
  'SKIP'
  '0e1f1f222f28ac8851e7f2803908ef1b3e6a4bb51ad953d8d29fd001c034b9f7'
)

pkgver() {
  cd "${_plug}"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "${_plug}"
  patch -p1 -i "${srcdir}/0001.patch"
}

build() {
  arch-meson "${_plug}/VapourSynth" build --buildtype=release
  meson compile -C build
}

package(){
  DESTDIR="${pkgdir}" meson install -C build
  install -Dm644 "${_plug}/VapourSynth/README.md" "${pkgdir}/usr/share/doc/vapoursynth/plugins/${_plug}/README.md"
}
