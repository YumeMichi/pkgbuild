# Maintainer: Gustavo Alvarez <sl1pkn07@gmail.com>

_plug=lsmashsource
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=r1293.e990901
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT version)"
arch=('x86_64')
url='https://forum.doom9.org/showthread.php?t=167435'
license=('LGPL')
depends=(
  'vapoursynth'
  'libavutil.so'
  'libavformat.so'
  'libavcodec.so'
  'libswscale.so'
)
makedepends=(
  'git'
  'cmake'
)
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
source=("${_plug}::git+https://github.com/HomeOfAviSynthPlusEvolution/L-SMASH-Works.git")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "${_plug}"
  git submodule update --init
}

build() {
  cmake -S "${_plug}" -B build \
    -DBUILD_AVS_PLUGIN=OFF \
    -DENABLE_DAV1D=OFF \
    -DENABLE_MFX=OFF \
    -DENABLE_XML2=OFF \
    -DENABLE_VPX=OFF \
    -DENABLE_VULKAN=OFF \
    -DZLIB_USE_STATIC_LIBS=OFF \
    -DCMAKE_BUILD_TYPE=Release

  cmake --build build
}

package() {
  _sitepkgs="$(python -c 'import site; print(site.getsitepackages()[0])')"
  install -Dm755 "build/libLSMASHSource.so" "${pkgdir}${_sitepkgs}/vapoursynth/plugins/lsmashsource.so"
  install -Dm644 "${_plug}/VapourSynth/README.md" "${pkgdir}/usr/share/doc/vapoursynth/plugins/${_plug}/README.md"
}
