# Contributor: Mikuro Kagamine <mikurok@forgecrushing.com>

_plug=znedi3
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=3.0.g4cf67b9
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT Version)"
arch=('x86_64')
url='https://github.com/sekrit-twc/znedi3'
license=('GPL2')
depends=(
  'vapoursynth'
  'vapoursynth-plugin-nnedi3_weights_bin'
)
makedepends=('git')
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
source=("${_plug}::git+https://github.com/sekrit-twc/${_plug}.git")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  echo "$(git describe --long --tags | tr - . | tr -d r)"
}

prepare() {
  cd "${_plug}"
  git submodule update --init

  # use system vapoursynth headers
  rm -fr vsxx/VapourSynth

  sed -e "s| -Ivsxx/vapoursynth||g" \
      -e '/VSConstants4.h/d' \
      -e '/VapourSynth4.h/d' \
      -e '/VSHelper4.h/d'\
      -i Makefile
}

build() {
  CXXFLAGS="${CXXFLAGS/-fno-plt/-fplt}"
  CPPFLAGS+=" $(pkg-config --cflags vapoursynth) "
  echo ${CPPFLAGS}
  LDFLAGS="${LDFLAGS/-z,now/-z,lazy}"

  make -C "${_plug}" X86=1 X86_AVX512=1
}

package(){
  _sitepkgs=$(python -c "import site; print(site.getsitepackages()[0])")
  install -Dm755 "${_plug}/vsznedi3.so" "${pkgdir}/${_sitepkgs}/vapoursynth/plugins/libvsznedi3.so"
  install -Dm644 "${_plug}/readme.rst" "${pkgdir}/usr/share/doc/vapoursynth/plugins/${_plug}/readme.rst"
}
