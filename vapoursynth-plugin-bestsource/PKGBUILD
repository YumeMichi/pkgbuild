# Maintainer: witchymary
# Maintainer: Sean Du <do4suki@gmail.com>

_plug=bestsource
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=r411.ecfc9a3
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT version)"
arch=('x86_64')
url='https://forum.doom9.org/showthread.php?p=1972253'
license=('MIT')
depends=(
  'vapoursynth'
  'libavcodec.so'
  'libavformat.so'
  'jansson'
)
makedepends=(
  'git'
  'meson'
)
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
  'libbestsource.so'
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
source=("${_plug}::git+https://github.com/vapoursynth/bestsource.git")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "${_plug}"
  rm -rf dist build
  git submodule update --init
}

build() {
  cd "${_plug}"
  python -m build --wheel
}

package(){
  cd "${_plug}"
  python -m installer --destdir="${pkgdir}" dist/*.whl
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
