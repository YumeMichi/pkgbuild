# Maintainer: Josh Holmer <jholmer.in@gmail.com>

_plug=resize2
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=r43.f602b8a
pkgrel=1
pkgdesc="Plugin for VapourSynth: ${_plug} (GIT version)"
arch=('x86_64')
url='https://github.com/Jaded-Encoding-Thaumaturgy/vapoursynth-resize2'
license=('LGPL-2.1-or-later')
depends=('vapoursynth' 'zimg')
makedepends=('git' 'meson' 'ninja')
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
_tag=0.4.0
source=("${_plug}::git+https://github.com/Jaded-Encoding-Thaumaturgy/vapoursynth-resize2.git#tag=${_tag}")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "${_plug}"
  meson subprojects download
}

build() {
  arch-meson "${_plug}" build --buildtype=release
  meson compile -C build
}

package() {
  DESTDIR="${pkgdir}" meson install -C build
  install -Dm644 "${_plug}/ReadMe.md" "${pkgdir}/usr/share/doc/vapoursynth/plugins/${_plug}/README.md"
}
