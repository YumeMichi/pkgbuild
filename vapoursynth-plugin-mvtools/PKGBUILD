# Maintainer: Gustavo Alvarez <sl1pkn07@gmail.com>

_plug=mvtools
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=26.0.gc8d83aa
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT version)"
arch=('x86_64')
url="https://forum.doom9.org/showthread.php?t=171207"
license=('GPL')
depends=(
  'vapoursynth'
  'fftw'
)
makedepends=(
  'git'
  'nasm'
  'meson'
)
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
source=("${_plug}::git+https://github.com/dubhatervapoursynth/vapoursynth-${_plug}.git")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  echo "$(git describe --long --tags | tr - . |tr -d v)"
}

prepare() {
  cd "${_plug}"
  rm -rf dist build
  git submodule update --init
}

build() {
  cd "${_plug}"
  python -m build --wheel
}

package() {
  cd "${_plug}"
  python -m installer --destdir="${pkgdir}" dist/*.whl
  install -Dm644 readme.rst "${pkgdir}/usr/share/doc/vapoursynth/plugins/${_plug}/readme.rst"
}
