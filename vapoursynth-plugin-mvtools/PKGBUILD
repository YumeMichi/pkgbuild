# Maintainer: Gustavo Alvarez <sl1pkn07@gmail.com>

_plug=mvtools
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=24.12.gfee9a1b
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT version)"
arch=('x86_64')
url="https://forum.doom9.org/showthread.php?t=171207"
license=('GPL')
depends=(
  'vapoursynth'
  'fftw'
)
makedepends=(
  'git'
  'nasm'
  'meson'
)
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
_commit=fee9a1bf4a0a3e93ecb76e4e82418cb4c5dff391
source=("${_plug}::git+https://github.com/dubhatervapoursynth/vapoursynth-${_plug}.git#commit=${_commit}")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  echo "$(git describe --long --tags | tr - . |tr -d v)"
}

build() {
  arch-meson "${_plug}" build --buildtype=release
  meson compile -C build
}

package() {
  DESTDIR="${pkgdir}" meson install -C build
  install -Dm644 "${_plug}/readme.rst" "${pkgdir}/usr/share/doc/vapoursynth/plugins/${_plug}/readme.rst"
}
