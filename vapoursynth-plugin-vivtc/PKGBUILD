# Maintainer:  Joshua Holmer <jholmer.in@gmail.com>

_plug=vivtc
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=R1.4.g4ac661d
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT version)"
arch=('any')
url='https://github.com/vapoursynth/vivtc'
license=('MIT')
depends=('vapoursynth')
makedepends=(
  'git'
  'meson'
)
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
_commit=4ac661d78eaf8b5ab7c5dd2d05c81234fe9aaca8
source=("${_plug}::git+https://github.com/vapoursynth/vivtc.git#commit=${_commit}")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  echo "$(git describe --long --tags | tr - .)"
}

build() {
  arch-meson "${_plug}" build
  meson compile -C build
}

package() {
  DESTDIR="${pkgdir}" meson install -C build

  install -Dm644 "${_plug}/docs/vivtc.rst" "${pkgdir}/usr/share/doc/vapoursynth/plugins/${_plug}/README.rst"
}
