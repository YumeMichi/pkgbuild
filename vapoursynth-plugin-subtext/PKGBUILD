# Maintainer:  Joshua Holmer <jholmer.in@gmail.com>

_plug=subtext
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=R6.4.gef0e4c5
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT version)"
arch=('any')
url='https://github.com/vapoursynth/subtext'
license=('MIT')
depends=(
  'vapoursynth'
  'libass'
  'ffmpeg'
)
makedepends=(
  'git'
  'meson'
)
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
source=("${_plug}::git+https://github.com/vapoursynth/subtext.git")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  echo "$(git describe --long --tags | tr - .)"
}

prepare() {
  cd "${_plug}"
  rm -rf dist build
}

build() {
  cd "${_plug}"
  python -m build --wheel
}

package() {
  cd "${_plug}"
  python -m installer --destdir="${pkgdir}" dist/*.whl
  install -Dm644 README.md "${pkgdir}/usr/share/doc/vapoursynth/plugins/${_plug}/README.md"
}
