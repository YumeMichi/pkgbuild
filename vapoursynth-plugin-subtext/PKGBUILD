# Maintainer:  Joshua Holmer <jholmer.in@gmail.com>

_plug=subtext
pkgname=vapoursynth-plugin-${_plug}-yumemichi
pkgver=R5.5.gd03b913
pkgrel=1
pkgdesc="Plugin for Vapoursynth: ${_plug} (GIT version)"
arch=('any')
url='https://github.com/vapoursynth/subtext'
license=('MIT')
depends=(
  'vapoursynth'
  'libass'
  'ffmpeg'
)
makedepends=(
  'git'
  'meson'
)
provides=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
conflicts=(
  "vapoursynth-plugin-${_plug}"
  "vapoursynth-plugin-${_plug}-git"
)
_commit=d03b9131aacd2f541be6440dca728773fe8a53e3
source=("${_plug}::git+https://github.com/vapoursynth/subtext.git#commit=${_commit}")
sha256sums=('SKIP')

pkgver() {
  cd "${_plug}"
  echo "$(git describe --long --tags | tr - .)"
}

build() {
  arch-meson "${_plug}" build --buildtype=release
  meson compile -C build
}

package() {
  DESTDIR="${pkgdir}" meson install -C build

  install -Dm644 "${_plug}"/docs/subtext.rst "${pkgdir}/usr/share/doc/vapoursynth/plugins/${_plug}/README.rst"
}
